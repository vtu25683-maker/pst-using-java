 public static PerformOperation isPalindrome() {     return i -> { 
      String numberStr = String.valueOf(i); 
      String reversedStr = ""; 
      
      for (int j=numberStr.length()-1; j>=0; j--) {         reversedStr += numberStr.charAt(j); 
      } 
      return numberStr.equals(reversedStr); 
    }; 
 } 
