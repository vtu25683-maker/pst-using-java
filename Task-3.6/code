import java.util.*;

class Solution {
    public String[] sortPeople(String[] names, int[] heights) {
        // Create a map to store height -> name
        // We use Collections.reverseOrder() so the map sorts keys descending
        Map<Integer, String> map = new TreeMap<>(Collections.reverseOrder());
        
        for (int i = 0; i < names.length; i++) {
            map.put(heights[i], names[i]);
        }
        
        String[] result = new String[names.length];
        int index = 0;
        
        // Iterate through the sorted keys and fill the result array
        for (int height : map.keySet()) {
            result[index++] = map.get(height);
        }
        
        return result;
    }
}
