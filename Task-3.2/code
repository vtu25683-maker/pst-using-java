import java.util.Scanner;

public class Solution {

    public static String getSmallestAndLargest(String s, int k) {
        // Initialize smallest and largest with the first possible substring
        String currentSubstring = s.substring(0, k);
        String smallest = currentSubstring;
        String largest = currentSubstring;
        
        // Loop through the string to extract all substrings of length k
        // The loop ends at s.length() - k to prevent going out of bounds
        for (int i = 1; i <= s.length() - k; i++) {
            currentSubstring = s.substring(i, i + k);
            
            // compareTo returns < 0 if currentSubstring is alphabetically smaller
            if (currentSubstring.compareTo(smallest) < 0) {
                smallest = currentSubstring;
            }
            
            // compareTo returns > 0 if currentSubstring is alphabetically larger
            if (currentSubstring.compareTo(largest) > 0) {
                largest = currentSubstring;
            }
        }
        
        return smallest + "\n" + largest;
    }

    public static void main(String[] args) {
        Scanner scan = new Scanner(System.in);
        
        // Read string s and integer k from standard input
        if (scan.hasNext()) {
            String s = scan.next();
            int k = scan.nextInt();
            scan.close();
            
            // Print the result from our comparison method
            System.out.println(getSmallestAndLargest(s, k));
        }
    }
}
